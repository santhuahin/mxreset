<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — MXReset</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f5;
      color: #333;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 40px 16px;
    }

    .card {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      padding: 32px;
      width: 100%;
      max-width: 480px;
    }

    .card-wide {
      max-width: 900px;
    }

    h1 {
      font-size: 1.4rem;
      margin-bottom: 8px;
      color: #111;
    }

    p.subtitle {
      font-size: 0.9rem;
      color: #666;
      margin-bottom: 24px;
    }

    label {
      display: block;
      font-size: 0.875rem;
      font-weight: 500;
      margin-bottom: 6px;
      color: #444;
    }

    input[type="email"],
    input[type="password"],
    input[type="text"],
    input[type="file"] {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 0.95rem;
      margin-bottom: 16px;
      outline: none;
      transition: border-color 0.15s;
    }

    input:focus {
      border-color: #4f7ef8;
    }

    button[type="submit"], .btn {
      display: inline-block;
      padding: 10px 20px;
      background: #4f7ef8;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 0.95rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.15s;
    }

    button[type="submit"]:hover, .btn:hover {
      background: #3a6ae0;
    }

    .btn-danger {
      background: #e05252;
    }

    .btn-danger:hover {
      background: #c03a3a;
    }

    .btn-sm {
      padding: 6px 12px;
      font-size: 0.8rem;
    }

    .alert {
      padding: 12px 16px;
      border-radius: 6px;
      margin-bottom: 20px;
      font-size: 0.9rem;
    }

    .alert-success {
      background: #e6f4ea;
      color: #2e7d32;
      border: 1px solid #a5d6a7;
    }

    .alert-error {
      background: #fdecea;
      color: #c62828;
      border: 1px solid #ef9a9a;
    }

    .alert-info {
      background: #e3f2fd;
      color: #1565c0;
      border: 1px solid #90caf9;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
      margin-bottom: 24px;
    }

    th {
      text-align: left;
      padding: 10px 12px;
      background: #f0f0f0;
      font-weight: 600;
      border-bottom: 2px solid #ddd;
    }

    td {
      padding: 10px 12px;
      border-bottom: 1px solid #eee;
      vertical-align: middle;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .section-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 12px;
      color: #222;
    }

    .form-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .form-row input {
      flex: 1;
      min-width: 200px;
    }

    hr {
      border: none;
      border-top: 1px solid #eee;
      margin: 28px 0;
    }

    nav {
      width: 100%;
      max-width: 900px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }

    nav .brand {
      font-weight: 700;
      font-size: 1.1rem;
      color: #111;
      text-decoration: none;
    }

    nav a {
      font-size: 0.875rem;
      color: #4f7ef8;
      text-decoration: none;
    }

    nav a:hover {
      text-decoration: underline;
    }

    .empty-state {
      text-align: center;
      color: #888;
      padding: 24px;
      font-size: 0.9rem;
    }

    .failed-list {
      list-style: none;
      margin-top: 8px;
    }

    .failed-list li {
      font-size: 0.8rem;
      color: #c62828;
      padding: 2px 0;
    }
  </style>
</head>
<body>
